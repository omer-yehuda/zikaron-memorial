# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# AWS DynamoDB — persistent candle counts (no open ports, permanent free tier)
# On Amplify: credentials come from the IAM service role automatically (no keys needed).
# For local dev: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY in .env.local manually.
# Leave DYNAMO_TABLE empty to use in-memory fallback (data resets on cold start).
DYNAMO_TABLE=ZikaronMemorial
DYNAMO_REGION=us-east-1
