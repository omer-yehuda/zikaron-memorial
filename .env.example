# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# AWS DynamoDB — persistent candle counts (no open ports, permanent free tier)
# Get these from: AWS Console → IAM → Users → your user → Security credentials
# Leave empty to use in-memory fallback (data resets on cold start).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
DYNAMO_TABLE=ZikaronMemorial
