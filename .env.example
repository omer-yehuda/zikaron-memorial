# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# AWS credentials — only needed for local dev outside Amplify
# On Amplify, IAM role provides access automatically
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# DynamoDB table names (created by setup script or manually)
# Leave unset to use local JSON data (dev mode)
DYNAMODB_SOLDIERS_TABLE=ZikaronSoldiers
DYNAMODB_CANDLES_TABLE=ZikaronCandles
